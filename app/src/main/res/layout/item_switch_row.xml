<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="86dp"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingLeft="18dp"
    android:paddingRight="18dp">
    <ImageView android:id="@+id/img_switch_icon" style="@style/ProfileOptionIcon" android:src="@drawable/ic_settings_notifications" />
    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="18dp" android:layout_weight="1" android:orientation="vertical">
        <TextView android:id="@+id/txt_switch_title" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/title_placeholder" android:textColor="#071827" android:textSize="17sp" android:textStyle="bold" />
        <TextView android:id="@+id/txt_switch_subtitle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="5dp" android:text="@string/description" android:textColor="#667085" android:textSize="14sp" />
    </LinearLayout>
    <com.google.android.material.switchmaterial.SwitchMaterial android:id="@+id/switch_row_switch" android:layout_width="wrap_content" android:layout_height="wrap_content" />
</LinearLayout>
