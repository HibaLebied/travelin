<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:paddingLeft="20dp"
    android:paddingTop="0dp"
    android:paddingRight="20dp"
    android:paddingBottom="20dp"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <include layout="@layout/view_preferences_header" />

        <TextView
            style="@style/ProfilePageDescription"
            android:text="@string/preferences_intro" />

        <LinearLayout
            style="@style/ProfileSectionCard"
            android:layout_marginTop="26dp">

            <TextView
                style="@style/ProfileSectionLabel"
                android:text="@string/general_settings" />

            <LinearLayout
                android:id="@+id/row_language"
                style="@style/ProfileOptionRow">

                <ImageView
                    style="@style/ProfileOptionIcon"
                    android:src="@drawable/ic_settings_language" />

                <TextView
                    style="@style/ProfileOptionTitle"
                    android:layout_weight="1"
                    android:text="@string/language" />

                <TextView
                    android:id="@+id/txt_language_value"
                    style="@style/ProfileOptionValue"
                    android:text="@string/french" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/row_currency"
                style="@style/ProfileOptionRow">

                <ImageView
                    style="@style/ProfileOptionIcon"
                    android:src="@drawable/ic_settings_currency" />

                <TextView
                    style="@style/ProfileOptionTitle"
                    android:layout_weight="1"
                    android:text="@string/currency" />

                <TextView
                    android:id="@+id/txt_currency_value"
                    style="@style/ProfileOptionValue"
                    android:text="@string/mad_currency" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            style="@style/ProfileSectionCard"
            android:layout_marginTop="18dp">

            <TextView
                style="@style/ProfileSectionLabel"
                android:text="@string/notifications_alerts" />

            <include
                layout="@layout/item_switch_row"
                android:id="@+id/row_notifications" />
            <include
                layout="@layout/item_switch_row"
                android:id="@+id/row_reminders" />
        </LinearLayout>

        <LinearLayout
            style="@style/ProfileSectionCard"
            android:layout_marginTop="18dp">

            <TextView
                style="@style/ProfileSectionLabel"
                android:text="@string/experience" />

            <include
                layout="@layout/item_switch_row"
                android:id="@+id/row_offline" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_save_preferences"
            style="@style/ProfilePrimaryButton"
            android:layout_marginTop="26dp"
            android:text="@string/save_preferences" />
    </LinearLayout>
</ScrollView>
